# SharePoint Configuration
# Copy this file to .env and fill in your credentials

# Azure AD Application Credentials
SHAREPOINT_CLIENT_ID=6f9ebeed-1c0c-4cdb-a7cb-19718966e3bc
SHAREPOINT_CLIENT_SECRET=your-client-secret-here
SHAREPOINT_TENANT_ID=your-tenant-id-here

# SharePoint Site
SHAREPOINT_SITE_URL=https://cisco.sharepoint.com/sites/Splunk-Product-Compliance

# Splunk HEC Configuration (Optional)
SPLUNK_HOST=your-stack.splunkcloud.com
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_INDEX=product_compliance
